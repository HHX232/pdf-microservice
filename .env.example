# Server Configuration
PORT=3001
NODE_ENV=development

# CORS Configuration
# Comma-separated list of allowed origins
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# Security — shared secret, sent as x-api-key header by callers
API_SECRET_KEY=your-secret-key-here

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# File Upload Limits
MAX_FILE_SIZE_MB=50

# ─── Email / Resend ──────────────────────────────────────────────────────────
# Sign up free at https://resend.com → API Keys → Create API Key
RESEND_API_KEY=re_your_api_key_here

# "From" address. Without a verified domain use: onboarding@resend.dev
# With verified domain: GoodWorker <noreply@yourdomain.com>
RESEND_FROM="GoodWorker <onboarding@resend.dev>"
